{
  "name": "astro-theme-pure",
  "type": "module",
  "version": "4.1.4",
  "scripts": {
    "dev": "astro dev",
    "dev:check": "astro check --watch & astro dev",
    "build": "astro-pure check && astro check && astro build && npm run build:pages",
    "build:pages": "rm -rf dist/server/.prerender && cp -r dist/server dist/client/_worker.js && mv dist/client/_worker.js/entry.mjs dist/client/_worker.js/index.js",
    "preview": "astro preview",
    "sync": "astro sync",
    "check": "astro check",
    "astro": "astro",
    "pure": "astro-pure",
    "format": "prettier --write  '**/*.{js,jsx,ts,tsx,md,mdx,astro}'",
    "lint": "eslint --fix 'src/**/*.{js,ts,jsx,tsx,astro}'",
    "yijiansilian": "bun lint && bun sync && bun check && bun format",
    "clean": "rm -rf .astro dist .wrangler",
    "deploy": "wrangler pages deploy dist/client",
    "cache:avatars": "tsx preset/scripts/cacheAvatars.ts"
  },
  "dependencies": {
    "@astrojs/check": "0.9.8",
    "@astrojs/cloudflare": "13.1.0",
    "@astrojs/compiler-rs": "^0.1.8",
    "@astrojs/rss": "4.0.18",
    "@waline/client": "^3.13.0",
    "astro": "6.1.8",
    "astro-pure": "1.4.6",
    "katex": "^0.16.45",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^10.2.1",
    "eslint-plugin-astro": "^1.7.0",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "wrangler": "^4.90.0"
  }
}
