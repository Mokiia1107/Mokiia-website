{
	"version": 3,
	"routes": [
		{
			"src": "^/(.*)/$",
			"headers": {
				"Location": "/$1"
			},
			"status": 308
		},
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)$",
			"dest": "_render"
		},
		{
			"src": "^/_image$",
			"dest": "_render"
		},
		{
			"src": "^/404$",
			"dest": "_render"
		},
		{
			"src": "^/about$",
			"dest": "_render"
		},
		{
			"src": "^/blog/blog1$",
			"dest": "_render"
		},
		{
			"src": "^/blog/blog2$",
			"dest": "_render"
		},
		{
			"src": "^/blog/blog3$",
			"dest": "_render"
		},
		{
			"src": "^/blog/blog4$",
			"dest": "_render"
		},
		{
			"src": "^/blog/blog5$",
			"dest": "_render"
		},
		{
			"src": "^/blog/blog6$",
			"dest": "_render"
		},
		{
			"src": "^/docs/rss\\.xml$",
			"dest": "_render"
		},
		{
			"src": "^/docs$",
			"dest": "_render"
		},
		{
			"src": "^/links$",
			"dest": "_render"
		},
		{
			"src": "^/projects$",
			"dest": "_render"
		},
		{
			"src": "^/robots\\.txt$",
			"dest": "_render"
		},
		{
			"src": "^/rss\\.xml$",
			"dest": "_render"
		},
		{
			"src": "^/search$",
			"dest": "_render"
		},
		{
			"src": "^/tags$",
			"dest": "_render"
		},
		{
			"src": "^/terms/copyright$",
			"dest": "_render"
		},
		{
			"src": "^/terms/disclaimer$",
			"dest": "_render"
		},
		{
			"src": "^/terms/privacy-policy$",
			"dest": "_render"
		},
		{
			"src": "^/terms/terms-and-conditions$",
			"dest": "_render"
		},
		{
			"src": "^/terms$",
			"dest": "_render"
		},
		{
			"src": "^/$",
			"dest": "_render"
		},
		{
			"src": "^/.*$",
			"dest": "_render",
			"status": 404
		}
	],
	"images": {
		"sizes": [
			640,
			750,
			828,
			1080,
			1200,
			1920,
			2048,
			3840
		],
		"domains": [],
		"remotePatterns": [
			{
				"protocol": "https"
			}
		]
	}
}