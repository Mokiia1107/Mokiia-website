---
interface Props {
  id: number
  name_cn: string
  name: string
  url: string
  cover?: string
  coverFallback?: string
  date?: string
  rate?: number
  comment?: string
}

const { id, name_cn, name, url, cover, coverFallback, date, rate = 0, comment } = Astro.props

const displayName = name_cn || name
const displayOriginal = name_cn && name !== name_cn ? name : undefined
const fallbackSrc = coverFallback || `https://lain.bgm.tv/pic/cover/l/${id}.jpg`
---

<a
  class='group flex h-full flex-col overflow-hidden rounded-xl border no-underline transition-all hover:border-border hover:bg-muted'
  href={url}
  target='_blank'
  rel='noopener noreferrer'
>
  <img
    src={cover || fallbackSrc}
    alt={displayName}
    class='h-56 w-full object-cover'
    loading='lazy'
    onerror={`this.onerror=null;this.src='${fallbackSrc}'`}
  />
  <div class='flex flex-1 flex-col gap-1 p-3'>
    <div class='font-medium text-foreground transition-colors group-hover:text-primary'>
      {displayName}
    </div>
    {displayOriginal && <div class='text-sm text-muted-foreground'>{displayOriginal}</div>}
    <div class='mt-auto flex flex-wrap gap-x-2 gap-y-1 text-xs text-muted-foreground'>
      {date && <samp>{date}</samp>}
      {rate > 0 && <samp>{rate}/10</samp>}
    </div>
    {comment && <div class='truncate text-xs text-muted-foreground'>{comment}</div>}
  </div>
</a>
