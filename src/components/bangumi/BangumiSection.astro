---
import BangumiCard from './BangumiCard.astro'

interface BangumiItem {
  id: number
  name_cn: string
  name: string
  url: string
  cover?: string
  coverFallback?: string
  date?: string
  rate?: number
  comment?: string
}

interface Props {
  id: string
  title: string
  items: BangumiItem[]
}

const { id, title, items } = Astro.props
---

<h2 id={id}>{title}</h2>
{
  items.length > 0 ? (
    <ul class='not-prose grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-4'>
      {items.map((item) => (
        <li>
          <BangumiCard {...item} />
        </li>
      ))}
    </ul>
  ) : (
    <p class='text-sm text-muted-foreground'>暂无记录。</p>
  )
}
