---
import { Image } from 'astro:assets'

import { Quote } from 'astro-pure/advanced'
import { PostPreview } from 'astro-pure/components/pages'
import { getBlogCollection, sortMDByDate } from 'astro-pure/server'
import { Button, Card, Icon, Label } from 'astro-pure/user'
import PageLayout from '@/layouts/BaseLayout.astro'
import ProjectCard from '@/components/home/ProjectCard.astro'
import Section from '@/components/home/Section.astro'
import SkillLayout from '@/components/home/SkillLayout.astro'
import config from '@/site-config'

const languages = ['Html', 'JavaScript', 'CSS', 'Shell']
const frontend = ['TypeScript', 'Vite', 'Webpack', 'Astro']
const backend = ['Vercel', 'Waline']

const MAX_POSTS = 15
const allPosts = await getBlogCollection()
const allPostsByDate = sortMDByDate(allPosts).slice(0, MAX_POSTS)

const CATEGORIES = [
  { name: 'Impressions', slug: 'impressions' },
  { name: 'Linguistics', slug: 'linguistics' },
  { name: 'Pensées', slug: 'pensees' },
  { name: 'Protocol', slug: 'protocol' },
  { name: 'Fiction', slug: 'fiction' },
  { name: 'Photographie', slug: 'photographie' }
]

const postsByCategory = CATEGORIES.map(cat => {
  const posts = allPostsByDate.filter(
    (post) =>
      'category' in post.data &&
      typeof post.data.category === 'string' &&
      post.data.category.toLowerCase() === cat.name.toLowerCase()
  ).slice(0, 3)
  return { ...cat, posts }
})

const imagePath = config.logo.src
const images = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/*.{jpeg,jpg,png,gif,avif,webp}'
)
if (!images[imagePath])
  throw new Error(
    `"${imagePath}" does not exist in glob: "src/assets/*.{jpeg,jpg,png,gif,avif,webp}"`
  )
---

<PageLayout meta={{ title: 'Home' }} highlightColor='#659EB9'>
  <main class='flex w-full flex-col items-center'>
    <section class='animate mb-10 flex flex-col items-center gap-y-7' id='content-header'>
      <Image
        src={images[imagePath]()}
        alt={config.logo.alt || 'Profile'}
        class='h-28 w-auto rounded-full border p-1'
        loading='eager'
        fetchpriority='high'
      />

      <div class='flex flex-col items-center gap-y-4'>
        <h1 class='text-3xl font-medium'>{config.author}</h1>
        <div class='flex flex-wrap justify-center gap-x-7 gap-y-3'>
          <Label
            title='國境之南、太陽之西'
            as='a'
            href='https://www.readingtimes.com.tw/product/?pid=AIP0974'
            target='_blank'
          >
            <Icon name='location' class='size-5' slot='icon' />
          </Label>
          <Label
            title='Github'
            as='a'
            href='https://github.com/Mokiia1107'
            target='_blank'
          >
            <Icon name='github' class='size-5' slot='icon' />
          </Label>
        </div>
      </div>
    </section>

    <div id='content' class='animate flex flex-col gap-y-10 md:w-4/5 lg:w-5/6'>
      <Section title='About'>
        <p class='text-muted-foreground'>Writer / Sophomore</p>
        <p class='text-muted-foreground'>
          Major in molecular / information biology. She likes photography, linguistics and writes some stupid novels. Knowing well on Chinese & English, studying Russian & Japanese & French & Finnish
        </p>
        <Button title='More about me' class='w-fit self-end' href='/about' variant='ahead' />
      </Section>
      {
        allPostsByDate.length > 0 && (
          <section class='animate flex flex-col gap-y-5 md:flex-row md:gap-y-0'>
            <div class='text-xl font-medium md:min-w-36'>
              <h2>Posts</h2>
            </div>
            <div class='flex flex-1 flex-col gap-y-8'>
              {postsByCategory.map(({ name, slug, posts }) => (
                <div>
                  <h3 class='mb-3 text-lg font-medium'>
                    <a href={`/blog/category/${slug}`} class='hover:text-primary transition-colors'>
                      {name}
                    </a>
                  </h3>
                  {posts.length > 0 ? (
                    <ul class='ms-4 flex flex-col gap-y-2 pl-4'>
                      {posts.map((p) => (
                        <li class='flex flex-col gap-x-2 sm:flex-row'>
                          <PostPreview post={p} />
                        </li>
                      ))}
                    </ul>
                  ) : (
                    <p class='ms-4 text-sm text-muted-foreground pl-4'>
                      No posts yet.
                    </p>
                  )}
                </div>
              ))}
              <Button title='More posts' class='w-fit self-end' href='/blog' variant='ahead' />
            </div>
          </section>
        )
      }
      <Section title='Education'>
        <Card
          as='a'
          heading='Beijing 101 High School'
          subheading='International Department'
          date='2020 - 2023'
          href='https://www.beijing101.com/school/listArticle.do?schoolId=587bb213-aab9-415d-b129-b629de3718e8&navigationId=728fce67-ed6a-48c9-8c49-1561cc9c6c3c'
        />
        <Card
          as='a'
          heading='Capital Normal University'
          subheading='Department of Chemistry'
          date='2023 - 2024'
          href='https://hxx.cnu.edu.cn/'
        />
        <Card
          as='a'
          heading='Capital Normal University'
          subheading='College of Life Sciences'
          date='2024 - Present'
          href='https://smkxxy.cnu.edu.cn/'
        />
      </Section>

      <Section title='Website List'>
        <div class='grid grid-cols-1 gap-3 sm:grid-cols-2'>
          <ProjectCard
            href='https://www.youtube.com/watch?v=dQw4w9WgXcQ'
            heading='Lorem ipsum'
            subheading='Do not go gentle into that good night'
            imagePath='/src/assets/projects/1.avif'
          />
          <ProjectCard
            href='https://www.youtube.com/watch?v=dQw4w9WgXcQ'
            heading='Lorem ipsum'
            subheading='Old age burn and rave at close of day'
            imagePath='/src/assets/projects/2.avif'
          />
          <ProjectCard
            href='https://www.youtube.com/watch?v=dQw4w9WgXcQ'
            heading='Lorem ipsum'
            subheading='Rage, rage against the dying of the light'
            imagePath='/src/assets/projects/3.avif'
          />
          <ProjectCard
            href='/projects'
            heading='More projects'
            subheading='Check out more projects'
            imagePath='/src/assets/projects/4.avif'
          />
        </div>
      </Section>

      <Section title='Certifications'>
        <Card
          as='a'
          heading='Lorem ipsum'
          subheading='XXXX'
          date='July 2024'
          href='https://www.youtube.com/watch?v=dQw4w9WgXcQ'
        />
      </Section>

      <Section title='Skills'>
        <SkillLayout title='Languages' skills={languages} />
        <SkillLayout title='Frontend' skills={frontend} />
        <SkillLayout title='Backend' skills={backend} />
      </Section>
    </div>
    <Quote class='mt-12' />
  </main>
</PageLayout>
