---
import type { GetStaticPaths, Page } from 'astro'
import type { CollectionEntry } from 'astro:content'

import { Paginator } from 'astro-pure/components/pages'
import PostPreview from '@/components/pages/PostPreview.astro'
import { getBlogCollection, getUniqueTagsWithCount, sortMDByDate } from 'astro-pure/server'
import { Button, Icon } from 'astro-pure/user'
import PageLayout from '@/layouts/BaseLayout.astro'
import config from '@/site-config'

export const prerender = true

const CATEGORIES = [
  { name: 'Impressions', slug: 'impressions' },
  { name: 'Linguistics', slug: 'linguistics' },
  { name: 'Pensées', slug: 'pensees' },
  { name: 'Fiction', slug: 'fiction' },
  { name: 'Photographie', slug: 'photographie' }
]

export const getStaticPaths = (async ({ paginate }) => {
  const CATEGORIES = [
    { name: 'Impressions', slug: 'impressions' },
    { name: 'Linguistics', slug: 'linguistics' },
    { name: 'Pensées', slug: 'pensees' },
    { name: 'Fiction', slug: 'fiction' },
    { name: 'Photographie', slug: 'photographie' }
  ]

  const allCollections = sortMDByDate(await getBlogCollection()) as CollectionEntry<'blog'>[]
  const uniqueTags = getUniqueTagsWithCount(allCollections).map(([tag]) => tag)

  return CATEGORIES.flatMap((cat) => {
    const collections = allCollections.filter(
      (post) => post.data.category?.toLowerCase() === cat.name.toLowerCase()
    )
    return paginate(collections, {
      pageSize: config.content.blogPageSize,
      params: { category: cat.slug },
      props: { uniqueTags, categoryName: cat.name }
    })
  })
}) satisfies GetStaticPaths

interface Props {
  page: Page<CollectionEntry<'blog'>>
  uniqueTags: string[]
  categoryName: string
}

const { page, uniqueTags, categoryName } = Astro.props
const { category } = Astro.params

const meta = {
  description: `Posts in category ${categoryName}`,
  title: `${categoryName} - Blog`
}

const paginationProps = {
  ...(page.url.prev && {
    prevUrl: {
      text: `← Previous Posts`,
      url: page.url.prev
    }
  }),
  ...(page.url.next && {
    nextUrl: {
      text: `Next Posts →`,
      url: page.url.next
    }
  })
}
---

<PageLayout {meta}>
  <Button title='Back' href='/blog' variant='back' />
  <main class='mt-6 lg:mt-10'>
    <div id='content-header' class='animate'>
      <h1 class='mb-6 mt-6 text-3xl font-medium sm:mt-10'>{categoryName}</h1>
    </div>
    {
      page.data.length === 0 ? (
        <div class='grid gap-y-16 sm:grid-cols-[auto_3fr_1fr] sm:gap-x-8'>
          {/* left sidebar - categories */}
          <aside class='animate min-w-36' id='left-sidebar'>
            <h2 class='mb-3 text-lg font-medium'>Posts</h2>
            <ul class='flex flex-col gap-y-1.5'>
              <li>
                <a
                  href='/blog'
                  class='text-muted-foreground transition-colors hover:text-foreground'
                >
                  All Posts
                </a>
              </li>
              <ul class='ms-4 flex flex-col gap-y-1.5 pl-3'>
                {
                  CATEGORIES.map((cat) => (
                    <li>
                      <a
                        href={`/blog/category/${cat.slug}`}
                        class={
                          cat.slug === category
                            ? 'text-foreground font-medium'
                            : 'text-muted-foreground transition-colors hover:text-foreground'
                        }
                        aria-current={cat.slug === category ? 'page' : undefined}
                      >
                        {cat.name}
                      </a>
                    </li>
                  ))
                }
              </ul>
            </ul>
          </aside>

          <section class='animate' id='content'>
            <p class='text-muted-foreground'>No posts in this category yet.</p>
          </section>

          {/* right sidebar - tags */}
          {!!uniqueTags.length && (
            <aside class='animate' id='sidebar'>
              <h2 class='mb-4 flex items-center text-lg font-medium'>
                <Icon name='tag-2' class='me-2' />
                Tags
              </h2>
              <ul class='text-bgColor flex flex-wrap gap-2'>
                {
                  uniqueTags.slice(0, 50).map((tag) => (
                    <li>
                      <Button title={tag} href={`/tags/${tag}`} variant='pill' />
                    </li>
                  ))
                }
              </ul>
              <span class='mt-4 block sm:text-end'>
                <a aria-label='View all blog categories' href='/tags' data-astro-prefetch>
                  View all →
                </a>
              </span>
            </aside>
          )}
        </div>
      ) : (
        <div class='grid gap-y-16 sm:grid-cols-[auto_3fr_1fr] sm:gap-x-8'>
          {/* left sidebar - categories */}
          <aside class='animate min-w-36' id='left-sidebar'>
            <h2 class='mb-3 text-lg font-medium'>Posts</h2>
            <ul class='flex flex-col gap-y-1.5'>
              <li>
                <a
                  href='/blog'
                  class='text-muted-foreground transition-colors hover:text-foreground'
                >
                  All Posts
                </a>
              </li>
              <ul class='ms-4 flex flex-col gap-y-1.5 pl-3'>
                {
                  CATEGORIES.map((cat) => (
                    <li>
                      <a
                        href={`/blog/category/${cat.slug}`}
                        class={
                          cat.slug === category
                            ? 'text-foreground font-medium'
                            : 'text-muted-foreground transition-colors hover:text-foreground'
                        }
                        aria-current={cat.slug === category ? 'page' : undefined}
                      >
                        {cat.name}
                      </a>
                    </li>
                  ))
                }
              </ul>
            </ul>
          </aside>

          <section aria-label='Blog posts list' class='animate' id='content'>
            {/* header */}
            <div class='mb-3 flex flex-col justify-between text-sm sm:mb-5 sm:flex-row'>
              <span class='text-muted-foreground'>
                Page {page.currentPage} - Showing {page.data.length} of {page.total} posts
              </span>
              <a aria-label='View all blog by years' href='/archives' data-astro-prefetch>
                View all posts by years →
              </a>
            </div>
            {/* posts */}
            <ul class='flex flex-col gap-y-4 text-start'>
              {page.data.map((post) => (
                <PostPreview {post} detailed />
              ))}
            </ul>
            <Paginator {...paginationProps} />
          </section>

          {/* right sidebar - tags */}
          {!!uniqueTags.length && (
            <aside class='animate' id='sidebar'>
              <h2 class='mb-4 flex items-center text-lg font-medium'>
                <Icon name='tag-2' class='me-2' />
                Tags
              </h2>
              <ul class='text-bgColor flex flex-wrap gap-2'>
                {
                  uniqueTags.slice(0, 50).map((tag) => (
                    <li>
                      <Button title={tag} href={`/tags/${tag}`} variant='pill' />
                    </li>
                  ))
                }
              </ul>
              <span class='mt-4 block sm:text-end'>
                <a aria-label='View all blog categories' href='/tags' data-astro-prefetch>
                  View all →
                </a>
              </span>
            </aside>
          )}
        </div>
      )
    }
  </main>
</PageLayout>
