<%
if (page.menu_id == undefined) {
  page.menu_id = 'post';
}
if (page.title && page.wiki) {
  page.robots = 'noindex,follow';
}

var bookColors = [
  '#8B4513', '#556B2F', '#483D8B', '#800000', '#2F4F4F',
  '#4B0082', '#191970', '#8B0000', '#006400', '#A0522D',
  '#5D4037', '#455A64', '#3E2723', '#1B5E20', '#0D47A1'
];
%>

<div class="bookshelf-wrapper">
  <div class="bookshelf">
    <% var idx = 0; %>
    <% page.posts.each(function(post){ %>
      <% if (post.indexing != false) { %>
        <a class="book-spine<%= scrollreveal(' ') %>"
           href="<%= pretty_url(post.link || post.path) %>"
           style="--book-color: <%= bookColors[idx % bookColors.length] %>"
           title="<%= post.title ? post.title : date(post.date, config.date_format) %>">
          <div class="spine-content">
            <span class="spine-title"><%= post.title ? post.title : date(post.date, config.date_format) %></span>
            <span class="spine-date"><%= date(post.date, 'YYYY-MM-DD') %></span>
          </div>
        </a>
        <% idx++; %>
      <% } %>
    <% }) %>
  </div>
</div>

<%- partial('_partial/main/post_list/paginator') %>
